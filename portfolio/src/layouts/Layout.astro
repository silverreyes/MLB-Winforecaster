---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="MLB Win Probability Forecaster - calibrated pre-game win probabilities compared against Kalshi prediction market prices" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body>
    <main class="container">
      <slot />
    </main>
  </body>
</html>

<style is:global>
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    font-size: 16px;
  }

  body {
    background: #0a0a0f;
    color: #e8e6e3;
    font-family: 'DM Sans', system-ui, -apple-system, sans-serif;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  .container {
    max-width: 900px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }

  h1, h2, h3 {
    line-height: 1.2;
  }

  h1 {
    font-size: 2.25rem;
    font-weight: 700;
    color: #ffffff;
  }

  h2 {
    font-size: 1.5rem;
    font-weight: 700;
    color: #d4a843;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  p {
    margin-bottom: 1rem;
    color: #c0bdb8;
  }

  a {
    color: #d4a843;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  a:hover {
    color: #e8c060;
  }
</style>

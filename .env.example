# MLB Win Forecaster -- Environment Variables
# Copy to .env and fill in values before running docker compose up
#
# cp .env.example .env
# nano .env

# ============================================================
# IMPORTANT: Model artifacts must be copied to the VPS BEFORE
# running docker compose up. The API will fail to start without
# them. They are in .gitignore and are NOT included in the repo.
#
# Copy 7 files from local to VPS:
#   scp models/artifacts/*.joblib models/artifacts/model_metadata.json \
#       user@VPS_IP:/opt/mlb-winforecaster/models/artifacts/
#
# Files required (6 joblib + 1 json):
#   lr_sp_enhanced.joblib, lr_team_only.joblib
#   rf_sp_enhanced.joblib, rf_team_only.joblib
#   xgb_sp_enhanced.joblib, xgb_team_only.joblib
#   model_metadata.json
# ============================================================

# Required: Postgres database password
# Generate with: openssl rand -base64 24
POSTGRES_PASSWORD=change_me_generate_a_strong_password

# Optional: Kalshi API key for live market price fetching
# Leave empty to skip Kalshi price integration
# Get from: https://kalshi.com/settings/api-keys
KALSHI_API_KEY=
